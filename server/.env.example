# SnapTask Server Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_EXPIRES_IN=7d

# Database
DATABASE_PATH=./data/snaptask.db

# CORS Configuration
# Use comma-separated origins for multiple allowed origins
# Use * to allow all origins (not recommended for production)
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
