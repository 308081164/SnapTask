# SnapTask Client Environment Variables
# Copy this file to .env and fill in the values

# AI Configuration (DashScope / Qwen)
VITE_AI_API_KEY=your-dashscope-api-key
VITE_AI_MODEL=qwen2.5-vl-plus
VITE_AI_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1

# Cloud Sync Configuration
# Leave empty or comment out to use offline mode (single-machine mode)
VITE_SYNC_SERVER_URL=http://localhost:3000
